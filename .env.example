# Just Dee Dee Music local smoke setup.
# Start a local static server first:
#   python3 -m http.server 4173 --bind localhost
JDDM_E2E_BASE_URL=http://localhost:4173/index.html

# This path is under node_modules, which is already gitignored.
# Generate it with:
#   npm run e2e:auth:save
JDDM_E2E_STORAGE_STATE=node_modules/.cache/jddm-e2e/storage-state.json

# Dedicated Firebase Email/Password test account for storage-state generation.
# Do not commit real credentials.
JDDM_E2E_AUTH_EMAIL=jddm-smoke@example.com
JDDM_E2E_AUTH_PASSWORD=replace-with-local-secret

# Optional: pin the smoke suite to a known canonical venue id.
# JDDM_E2E_TEST_VENUE_ID=canonical-venue-id

# Firebase web app config for the Just Dee Dee Music Firebase project.
# Get these from Firebase Console > Project settings > General > Your apps >
# Web app > SDK setup and configuration > Config.
# Put real values in .env.local, then run:
#   npm run firebase:config:local
# This writes config/firebaseConfig.local.js, which is gitignored.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Automatic SMS reminders for Dee Dee.
# DEE_DEE_REMINDER_PHONE supports comma-separated recipients.
# Configure these as Firebase Functions secrets before deploy:
#   firebase functions:secrets:set TWILIO_ACCOUNT_SID
#   firebase functions:secrets:set TWILIO_AUTH_TOKEN
#   firebase functions:secrets:set TWILIO_FROM_NUMBER
#   firebase functions:secrets:set DEE_DEE_REMINDER_PHONE
#   firebase functions:secrets:set JDDM_APP_URL
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
DEE_DEE_REMINDER_PHONE=4403054062,2168499292
JDDM_APP_URL=https://outswarming.github.io/Just-Dee-Dee-Music-Map/
